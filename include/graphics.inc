; DMG background layout uses tile coordinates, not pixel coordinates.
DEF BG_MAP            EQU $9800
DEF BG_MAP_WIDTH      EQU 32
DEF BG_MAP_HEIGHT     EQU 32

DEF BOARD_WIDTH       EQU 9
DEF BOARD_HEIGHT      EQU 9
DEF BOARD_MAX_WIDTH   EQU 10
DEF BOARD_MAX_HEIGHT  EQU 10
DEF BOARD_MAX_CELLS   EQU BOARD_MAX_WIDTH * BOARD_MAX_HEIGHT
DEF BOARD_BG_X        EQU 5
DEF BOARD_BG_Y        EQU 4

DEF STATUS_BG_X       EQU 1
DEF STATUS_BG_Y       EQU 0

DEF TILE_BYTES        EQU 16
DEF GAME_BG_TILE_COUNT EQU 14
DEF PAUSE_FRAME_TILE_COUNT EQU 6
DEF FONT_UI_BEFORE_CURSOR_TILE_COUNT EQU 31
DEF FONT_UI_AFTER_CURSOR_TILE_COUNT EQU 8
DEF CURSOR_TILE_COUNT EQU 4

; BG tiles follow the order documented in PROJECT.md.
DEF TILE_CLOSED       EQU 0
DEF TILE_OPEN_0       EQU 1
DEF TILE_FLAG         EQU 10
DEF TILE_MINE         EQU 11
DEF TILE_EXPLODED_MINE EQU 12
DEF TILE_WRONG_FLAG   EQU 13
DEF TILE_BLANK        EQU 14
DEF TILE_PAUSE_TOP_LEFT EQU 15
DEF TILE_PAUSE_TOP_RIGHT EQU 16
DEF TILE_PAUSE_BOTTOM_LEFT EQU 17
DEF TILE_PAUSE_BOTTOM_RIGHT EQU 18
DEF TILE_PAUSE_HORIZONTAL EQU 19
DEF TILE_PAUSE_VERTICAL EQU 20
DEF TILE_DIGIT_0      EQU 21
DEF TILE_COLON        EQU 31
DEF TILE_LETTER_A     EQU 32
DEF TILE_LETTER_U     EQU 56
DEF TILE_LETTER_V     EQU TILE_LETTER_U + 1
DEF TILE_LETTER_W     EQU TILE_LETTER_U + 2
DEF TILE_LETTER_X     EQU TILE_LETTER_U + 3
DEF TILE_LETTER_Y     EQU TILE_LETTER_U + 4
DEF TILE_LETTER_Z     EQU TILE_LETTER_U + 5
DEF TILE_COPYRIGHT    EQU TILE_LETTER_Z + 1
DEF TILE_BLACK_RIGHT_TRIANGLE EQU TILE_COPYRIGHT + 1

; Cursor Sprite tiles stay at fixed VRAM tile IDs 52-55.
DEF TILE_CURSOR_TL    EQU 52
DEF TILE_CURSOR_TR    EQU TILE_CURSOR_TL + 1
DEF TILE_CURSOR_BL    EQU TILE_CURSOR_TL + 2
DEF TILE_CURSOR_BR    EQU TILE_CURSOR_TL + 3

DEF TITLE_LOGO_BG_X       EQU 0
DEF TITLE_LOGO_BG_Y       EQU 1
DEF TITLE_LOGO_WIDTH      EQU 20
DEF TITLE_LOGO_HEIGHT     EQU 6
DEF TITLE_PRESS_START_X   EQU 4
DEF TITLE_PRESS_START_Y   EQU 10
DEF TITLE_COPYRIGHT_X     EQU 0
DEF TITLE_COPYRIGHT_Y     EQU 16
DEF TITLE_TEXT_ROW_WIDTH  EQU 20

DEF DIFFICULTY_TITLE_X  EQU 4
DEF DIFFICULTY_TITLE_Y  EQU 3
DEF DIFFICULTY_CURSOR_X EQU 4
DEF DIFFICULTY_ITEM_X   EQU 6
DEF DIFFICULTY_EASY_Y   EQU 6
DEF DIFFICULTY_NORMAL_Y EQU 8
DEF DIFFICULTY_HARD_Y   EQU 10

; Title BG tiles are loaded after the UI font symbol tiles.
DEF TILE_TITLE_BASE   EQU TILE_BLACK_RIGHT_TRIANGLE + 1
DEF TITLE_TILE_COUNT  EQU 71
