; Joypad register
DEF rP1   EQU $FF00

; LCD registers
DEF rLCDC EQU $FF40
DEF rSCY  EQU $FF42
DEF rSCX  EQU $FF43
DEF rLY   EQU $FF44
DEF rBGP  EQU $FF47
DEF rOBP0 EQU $FF48

; LCDC flags
DEF LCDCF_ON     EQU %10000000
DEF LCDCF_BG8000 EQU %00010000
DEF LCDCF_OBJON  EQU %00000010
DEF LCDCF_BG9800 EQU %00000000
DEF LCDCF_BGON   EQU %00000001

; Object Attribute Memory contains 40 four-byte Sprite entries.
DEF OAM_BASE EQU $FE00
DEF OAM_SIZE EQU 40 * 4

; APU registers
DEF rAUD1SWEEP EQU $FF10
DEF rAUD1LEN   EQU $FF11
DEF rAUD1ENV   EQU $FF12
DEF rAUD1LOW   EQU $FF13
DEF rAUD1HIGH  EQU $FF14
DEF rAUD2LEN   EQU $FF16
DEF rAUD2ENV   EQU $FF17
DEF rAUD2LOW   EQU $FF18
DEF rAUD2HIGH  EQU $FF19
DEF rAUD3ENA   EQU $FF1A
DEF rAUD3LEN   EQU $FF1B
DEF rAUD3LEVEL EQU $FF1C
DEF rAUD3LOW   EQU $FF1D
DEF rAUD3HIGH  EQU $FF1E
DEF rAUD4LEN   EQU $FF20
DEF rAUD4ENV   EQU $FF21
DEF rAUD4POLY  EQU $FF22
DEF rAUD4GO    EQU $FF23
DEF rAUDVOL    EQU $FF24
DEF rAUDTERM   EQU $FF25
DEF rAUDENA    EQU $FF26
DEF _AUD3WAVERAM EQU $FF30

; Writing a zero selects the corresponding active-low joypad group.
DEF P1F_GET_BUTTONS EQU %00010000
DEF P1F_GET_DPAD    EQU %00100000
DEF P1F_GET_NONE    EQU %00110000
